<?xml version="1.0" encoding="utf-8"?>
<!--
  Publish profile template for SmarterASP.NET Web Deploy / FTP.
  Download your site publish profile from the SmarterASP control panel,
  then copy Server, SiteName, Username, Password into this file.
-->
<Project ToolsVersion="4.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <WebPublishMethod>MSDeploy</WebPublishMethod>
    <PublishProvider>AzureWebSite</PublishProvider>
    <LastUsedBuildConfiguration>Release</LastUsedBuildConfiguration>
    <LastUsedPlatform>Any CPU</LastUsedPlatform>
    <SiteUrlToLaunchAfterPublish>https://YOUR-API-SUBDOMAIN.example.com/api/health</SiteUrlToLaunchAfterPublish>
    <LaunchSiteAfterPublish>true</LaunchSiteAfterPublish>
    <ProjectGuid>00000000-0000-0000-0000-000000000000</ProjectGuid>
    <DeployOnBuild>true</DeployOnBuild>
    <TargetFramework>net8.0</TargetFramework>
    <SelfContained>false</SelfContained>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <PublishUrl>YOUR_MSDeploy_URL_FROM_SMARTERASP</PublishUrl>
    <UserName>YOUR_SMARTERASP_USERNAME</UserName>
    <Password>YOUR_SMARTERASP_PASSWORD</Password>
    <_SavePWD>true</_SavePWD>
    <EnvironmentName>Production</EnvironmentName>
  </PropertyGroup>
</Project>
